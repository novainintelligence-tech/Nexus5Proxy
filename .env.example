# =============================================================================
# Environment Configuration Template for Nexus5Proxy
# =============================================================================
# Copy this file to .env and fill in the actual values
# NEVER commit .env files to version control
#

# =============================================================================
# Application Configuration
# =============================================================================

# Node.js environment (development | production)
NODE_ENV=production

# Server port
PORT=8080

# Logging level (debug | info | warn | error)
LOG_LEVEL=info

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection parameters
DB_USER=postgres
DB_PASSWORD=changeme_secure_password_here
DB_NAME=nexus5proxy
DB_HOST=postgres
DB_PORT=5432

# Full database URL (auto-generated if using individual params)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:changeme_secure_password_here@postgres:5432/nexus5proxy

# =============================================================================
# Authentication (Clerk)
# =============================================================================

# Clerk API Keys (get from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# =============================================================================
# API Configuration
# =============================================================================

# CORS allowed origins (comma-separated)
# Example: http://localhost:3000,https://example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# API timeout in milliseconds
API_TIMEOUT=30000

# =============================================================================
# Proxy Configuration (if applicable)
# =============================================================================

# HTTP Proxy (optional)
HTTP_PROXY=

# HTTPS Proxy (optional)
HTTPS_PROXY=

# No Proxy (comma-separated domains)
NO_PROXY=localhost,127.0.0.1

# =============================================================================
# Monitoring & Logging
# =============================================================================

# Log format (json | pretty)
LOG_FORMAT=json

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Enable error tracking (e.g., Sentry)
SENTRY_DSN=

# =============================================================================
# Security
# =============================================================================

# Session timeout (in minutes)
SESSION_TIMEOUT=60

# Rate limit (requests per minute)
RATE_LIMIT=100

# =============================================================================
# Feature Flags
# =============================================================================

# Feature flags for gradual rollout
FEATURE_FLAG_NEW_UI=false
FEATURE_FLAG_BETA_API=false

# =============================================================================
# External Services (if applicable)
# =============================================================================

# Third-party API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# =============================================================================
# Wallet Configuration (from .replit)
# =============================================================================

# Wallet addresses for crypto operations
WALLET_USDC=0xfe601096668c46d4bb0bd4e3c93751a3a8f4b3e5
WALLET_USDT_TRC20=TZADiUxhu9Y5bvJUMbMtBgFW43KqQ1hzaD
WALLET_BTC=1EqgNKJMmnnWpGjYZJAapDEyyXruXxLCYj

# =============================================================================
# Docker Specific
# =============================================================================

# Container resource limits
CONTAINER_MEMORY_LIMIT=1024m
CONTAINER_CPU_LIMIT=2

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# Development Only Settings
# =============================================================================

# Enable verbose debugging
DEBUG=false

# Hot-reload enabled (development only)
ENABLE_HOT_RELOAD=true

# Seed database on startup (development only)
SEED_DATABASE=false
